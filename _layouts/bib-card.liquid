---
---
<div class="pub-card-item">
  <div class="pub-card h-100">
    {% if entry.preview %}
      <div class="pub-card-img">
        {% if entry.preview contains '://' %}
          <img src="{{ entry.preview }}" alt="{{ entry.title }}">
        {% else %}
          {% assign entry_path = entry.preview | prepend: '/assets/img/publication_preview/' %}
          <img src="{{ entry_path | relative_url }}" alt="{{ entry.title }}">
        {% endif %}
      </div>
    {% else %}
      <div class="pub-card-img pub-card-img-placeholder">
        <i class="fa-regular fa-file-lines"></i>
      </div>
    {% endif %}
    <div class="pub-card-body">
      <div class="pub-card-title">{{ entry.title }}</div>
      <div class="pub-card-authors">
        {% assign limit = 3 %}
        {% for author in entry.author_array limit: limit %}
          {% assign author_last = author.last | regex_replace: '[*∗†‡§¶‖&^]', '' %}
          {% if site.scholar.last_name contains author_last %}
            <em>{{ author.first }} {{ author_last }}</em>
          {% else %}
            {{ author.first }} {{ author_last }}
          {% endif %}
          {% unless forloop.last %}, {% endunless %}
        {% endfor %}
        {% if entry.author_array.size > limit %} et al.{% endif %}
      </div>
      <div class="pub-card-journal">
        {% if entry.doi %}
          {% assign pub_link = entry.doi | prepend: 'https://doi.org/' %}
        {% elsif entry.url %}
          {% assign pub_link = entry.url %}
        {% else %}
          {% assign pub_link = '' %}
        {% endif %}
        {% capture journal_text %}<em>{% if entry.type == 'article' %}{{ entry.journal }}{% elsif entry.type == 'inproceedings' %}{{ entry.booktitle }}{% endif %}</em>{% if entry.year %}, {{ entry.year }}{% endif %}{% endcapture %}
        {% if pub_link != '' %}
          <a href="{{ pub_link }}" target="_blank" rel="noopener noreferrer">{{ journal_text }}</a>
        {% else %}
          {{ journal_text }}
        {% endif %}
      </div>
    </div>
  </div>
</div>
