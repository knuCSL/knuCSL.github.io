<!doctype html>
<html lang="{{ site.lang }}">
  <head>
    {% include head.liquid %}
  </head>

  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">
    {% include header.liquid %}

    <main role="main">
      <div class="lab-hero">
        <div class="lab-hero-image">
          <img src="{{ '/assets/img/ample_main.png' | relative_url }}" alt="{{ site.title }}">
        </div>
        <div class="lab-hero-panel">
          <div class="lab-hero-content">
            <div class="lab-hero-label">Kyungpook National University</div>
            <h1 class="lab-hero-title">{{ site.title }}</h1>
            <div class="lab-hero-desc">{{ content }}</div>
            <div class="lab-hero-links">
              <a href="{{ '/members/' | relative_url }}">Members &rarr;</a>
              <a href="{{ '/publications/' | relative_url }}">Publications &rarr;</a>
              <a href="{{ '/projects/' | relative_url }}">Projects &rarr;</a>
              <a href="{{ '/monitoring/' | relative_url }}">Climate Monitoring &rarr;</a>
            </div>
          </div>
        </div>
      </div>

      <div class="container lab-below-hero">
        {% if page.announcements and page.announcements.enabled %}
          <h2><a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a></h2>
          {% include news.liquid limit=true %}
        {% endif %}

        {% if page.selected_papers %}
          <h2><a href="{{ '/publications/' | relative_url }}" style="color: inherit">Selected Publications</a></h2>
          {% include selected_papers.liquid %}
        {% endif %}
      </div>
    </main>

    {% include footer.liquid %}
    {% include scripts.liquid %}
  </body>
</html>
