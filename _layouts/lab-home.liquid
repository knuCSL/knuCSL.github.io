<!doctype html>
<html lang="{{ site.lang }}" class="lab-home">
  <head>
    {% include head.liquid %}
  </head>

  <body>
    <div class="lab-scroll-root">

      <div class="lab-hero">
        <div class="lab-hero-image">
          <img src="{{ '/assets/img/ample_main.png' | relative_url }}" alt="{{ site.title }}">
        </div>
        <div class="lab-hero-panel">
          <div class="lab-hero-content">
            <div class="lab-hero-label">Kyungpook National University</div>
            <h1 class="lab-hero-title">{{ site.title }}</h1>
            <div class="lab-hero-desc">{{ content }}</div>
            <div class="lab-hero-links">
              <a href="{{ '/members/prof/' | relative_url }}">Professor &rarr;</a>
              <a href="{{ '/members/' | relative_url }}">Members &rarr;</a>
              <a href="{{ '/publications/' | relative_url }}">Publications &rarr;</a>
            </div>
          </div>
        </div>
      </div>

      <div class="lab-second-section">
        <div class="container lab-below-hero">
          <div class="lab-section-header">
            <h2>Recent Publications</h2>
            <a href="{{ '/publications/' | relative_url }}" class="lab-all-link">All &rarr;</a>
          </div>
          {% include recent_papers.liquid %}
        </div>

        <div class="container" style="padding-bottom: 2rem; font-size: 0.85rem; color: var(--global-text-color-light); text-align: center;">
          Department of Geography, Kyungpook National University, 80 Daehak-ro, Buk-gu, Daegu, Republic of Korea. Tel: 053-950-5233
        </div>

        {% include footer.liquid %}
      </div>

    </div>

    {% include scripts.liquid %}
  </body>
</html>
